{
    "name": "multisect",
    "version": "0.1.0",
    "description": "Set-theoretic operations on arrays with counted multiset semantics, sorted merge paths, and explicit order contracts.",
    "keywords": [
        "array",
        "set",
        "multiset",
        "intersection",
        "difference",
        "union",
        "symmetric-difference",
        "subset",
        "same-value-zero"
    ],
    "license": "MIT",
    "author": "Xyra Sinclair",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/XyraSinclair/multisect.git"
    },
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "DESIGN.md"
    ],
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "test": "vitest run",
        "bench": "npm run build --silent && node bench.mjs",
        "release": "npm publish --access public",
        "prepublishOnly": "npm run test && npm run build"
    },
    "devDependencies": {
        "@types/node": "^24.0.0",
        "es-toolkit": "^1.39.10",
        "lodash": "^4.17.21",
        "ramda": "^0.30.1",
        "typescript": "^5.5.0",
        "vitest": "^1.6.0"
    }
}
